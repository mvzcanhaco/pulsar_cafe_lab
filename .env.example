# Copie este arquivo para .env e preencha os valores reais
APP_NAME="Pulsar Café Lab"
DEBUG=false
SECRET_KEY=troque-isso-em-producao

# Banco de dados (SQLite para dev, PostgreSQL para prod)
DATABASE_URL=sqlite+aiosqlite:///./pulsar_cafe.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/pulsar_cafe

# Fiserv / Sitef — CliSiTef local server
FISERV_SITEF_IP=127.0.0.1
FISERV_SITEF_PORT=4096
FISERV_COMPANY_ID=00000000000000   # CNPJ da empresa (14 dígitos)
FISERV_TERMINAL_ID=00000001        # ID do terminal PDV
FISERV_MERCHANT_CNPJ=00000000000100
FISERV_ISV_APP_ID=                 # ID ISV fornecido pela Fiserv
FISERV_API_VERSION=0
FISERV_TIMEOUT_SECONDS=60
